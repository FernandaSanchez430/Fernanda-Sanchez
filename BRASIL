    <style>
        /* CONFIGURACIÓN DEL FONDO Y CENTRADO GENERAL */
        body {
            background-color: #e8f5e9; /* Fondo verde menta liso */
            font-family: Georgia, 'Times New Roman', Times, serif
            padding: 40px;
            color: #333;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center; /* Centra todo horizontalmente */
            text-align: center;  /* Centra el texto */
            font-size: 20px;
        }

        /* TÍTULOS */
        h1 {
            color: #009739; /* Verde Brasil */
            border-bottom: 3px solid #FFDF00; /* Amarillo Brasil */
            margin-bottom: 20px;
            padding-bottom: 10px;
            width: fit-content;
            font-size: 60px;
        }

        h2 {
            color: #002776; /* Azul Brasil */
            margin-top: 40px;
            font-size: 40px;
        }

        /* PÁRRAFOS */
        p {
            line-height: 1.6;
            max-width: 800px; /* Para que no se estire de más el texto */
            margin-bottom: 15px;
        }

        /* LISTAS (Centradas como bloque pero alineadas a la izquierda) */
        ul, ol {
            display: inline-block;
            text-align: left;
            margin-bottom: 20px;
            
            padding: 20px 40px;
            border-radius: 10px;
        }

        /* GALERÍA DE IMÁGENES */
        .galeria {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin: 30px 0;
            width: 100%;
        }

        .galeria img {
            border: 6px solid #FFDF00;
            border-radius: 15px;
            box-shadow: 5px 5px 15px rgba(0,0,0,0.1);
            width: 280px;    /* Todas del mismo ancho */
            height: 200px;   /* Todas del mismo alto */
            object-fit: cover; /* Para que no se deformen */
        }

        /* MULTIMEDIA (VIDEOS E IFRAMES) */
        video, iframe {
            display: block;
            margin: 20px auto;
            border-radius: 15px;
            max-width: 100%;
            box-shadow: 0px 4px 15px rgba(0,0,0,0.1);
            border: none;
        }

        /* ENLACES */
        a {
            color: #3063c9;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.1em;
            transition: 0.3s;
        }

        a:hover {
            color: #009739;
            text-decoration: underline;
        }

        hr {
            width: 60%;
            border: 0;
            border-top: 1px solid #ccc;
            margin: 40px 0;
        }
    </style>
